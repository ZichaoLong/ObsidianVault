# Obsidian configuration is device-local by default.
.obsidian/*

# Sync shared CSS snippets across desktop/mobile vaults.
!.obsidian/snippets/
!.obsidian/snippets/**

# Sync the Auto Heading plugin and its visual-numbering config.
!.obsidian/plugins/
.obsidian/plugins/*
!.obsidian/plugins/auto-heading/
!.obsidian/plugins/auto-heading/**
